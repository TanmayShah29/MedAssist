# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — commit ONLY .env.example; never .env.local or .env.production
.env
.env.local
.env.development.local
.env.test.local
.env.production
.env.production.local
# Do NOT add a blanket .env* rule — it would hide .env.example from git

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry CLI auth token (auto-created by Sentry wizard)
.sentryclirc
