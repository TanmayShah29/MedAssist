# ─────────────────────────────────────────────────────────────
# MedAssist — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────
# The app will throw an error on startup if any of these are missing.

# Supabase project URL (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous key (safe for client-side use)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (server-only, bypasses RLS for saves)
# Found in: Project Settings → API → service_role
# WARNING: Never expose this on the client side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq API key for AI lab report analysis (Llama 3.3 70B)
# Get one at: https://console.groq.com
GROQ_API_KEY=gsk_your_key

# ── OPTIONAL ──────────────────────────────────────────────────
# The app works without these, but features will be degraded.

# OCR.space API key — enables scanned/image-based PDF support.
# Without this, only digital (text-based) PDF lab reports are supported.
# Get a free key at: https://ocr.space/ocrapi
OCR_SPACE_API_KEY=your_ocr_key

# Base URL — used for absolute URLs in emails/redirects (optional in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
