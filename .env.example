# ─────────────────────────────────────────────────────────────────────────────
# MedAssist — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# The app throws an error on startup if any of these are missing.

# Supabase project URL (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous key — safe for client-side use
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — server-only, bypasses RLS for saves
# Found at: Project Settings → API → service_role
# ⚠️  WARNING: Never expose this on the client side or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq API key for AI lab report analysis (Llama 3.3 70B)
# Get one at: https://console.groq.com
GROQ_API_KEY=gsk_your_key

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# Features degrade gracefully without these.

# OCR.space API key — enables scanned/image-based PDF support.
# Without this, only digital (text-based) PDF lab reports are supported.
# Get a free key at: https://ocr.space/ocrapi
OCR_SPACE_API_KEY=your_ocr_key

# Public base URL — used for sitemaps, OG images, and canonical links.
# In production this should be your Vercel deployment URL or custom domain.
NEXT_PUBLIC_SITE_URL=https://medassist.health
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry DSN — enables error monitoring in production.
# Get one at: https://sentry.io → Create Project → Next.js
# Without this, errors are only logged to Vercel function logs.
SENTRY_DSN=

# Sentry org/project (required if SENTRY_DSN is set, for source maps upload)
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=medassist

# ── DEV / DEBUG ───────────────────────────────────────────────────────────────

# Set to 'true' to print INFO-level logs in production (default: off).
ENABLE_VERBOSE_LOGGING=false

# Set to 'true' to bypass IP-based rate limiting (useful in local dev
# when Supabase RPC is not set up). NEVER set this in production.
DISABLE_RATE_LIMIT=false
